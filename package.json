{
  "name": "xihe-agent",
  "version": "0.1.0",
  "description": "Xihe — a model-agnostic multi-agent runtime. Wright is its first agent: a terminal coding agent with plan mode, code mode, multi-perspective fan-out, a self-consolidating memory, an MCP router, and a curated skill bundle.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://xihe.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbyssCN/xihe.git"
  },
  "bugs": {
    "url": "https://github.com/AbyssCN/xihe/issues"
  },
  "keywords": [
    "agent",
    "coding-agent",
    "llm",
    "multi-agent",
    "orchestration",
    "harness",
    "model-agnostic",
    "deepseek",
    "mcp",
    "bun"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "xihe": "src/wright/tui.ts",
    "wright": "src/wright/tui.ts"
  },
  "files": [
    "src",
    "skills",
    "substrate",
    "assets",
    "umbrella.md",
    "manifest.json",
    "tsconfig.json",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "wright": "bun run src/wright/tui.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.77.0",
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oh-my-pi/hashline": "^15.7.6",
    "@sinclair/typebox": "^0.34.49",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typebox": "^1.1.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.0"
  }
}
