{
  "name": "oh-my-dag",
  "version": "0.2.0",
  "description": "oh-my-dag — a complete harness for the pi coding-agent runtime, in the oh-my-* tradition. A self-consolidating memory layer, a DAG execution engine (conductor → typed nodes → concurrent fan-out → cross-model verify → escalate on failure), plan mode with a read-only gate, an edit→verify tool gate, an MCP router, and a 17-skill bundle. Ships a bundled terminal agent; any OpenAI-compatible backend plugs in.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbyssCN/oh-my-dag.git"
  },
  "bugs": {
    "url": "https://github.com/AbyssCN/oh-my-dag/issues"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "harness",
    "oh-my",
    "dag",
    "workflow",
    "orchestration",
    "agent",
    "coding-agent",
    "memory",
    "llm",
    "multi-agent",
    "model-agnostic",
    "mcp",
    "bun"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "oh-my-dag": "src/harness/tui.ts",
    "omd": "src/harness/tui.ts"
  },
  "files": [
    "src",
    "skills",
    "substrate",
    "assets",
    "umbrella.md",
    "manifest.json",
    "tsconfig.json",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "omd": "bun run src/harness/tui.ts",
    "init": "bun run src/harness/tui.ts init",
    "dag-research": "bun run scripts/dag-research.ts",
    "dag-council": "bun run scripts/dag-council.ts",
    "dag-fanout": "bun run scripts/dag-fanout.ts",
    "dag-review": "bun run scripts/dag-review.ts",
    "dag-build": "bun run scripts/dag-build.ts",
    "omd-path": "bun run scripts/omd-path.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.77.0",
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oh-my-pi/hashline": "^15.7.6",
    "@sinclair/typebox": "^0.34.49",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typebox": "^1.1.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.0"
  }
}
