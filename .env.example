# =============================================================================
# Easiest path: run `omd init` — an interactive wizard configures the keys,
# picks a model, probes reachability, and writes this .env for you.
# Or set the values below manually.
#
# Naming note: OMD_* is the primary prefix. Legacy XIHE_* names are still
# accepted (mapped onto the OMD_* twin when it is unset — see src/env-alias.ts).
# =============================================================================

# --- runtime: pick any supported / OpenAI-compatible backend ---
# The agent has NO baked default — set both, or pass --provider/--model.
OMD_RUNTIME_PROVIDER=deepseek
OMD_RUNTIME_MODEL=deepseek-v4-pro

# --- provider credentials (set the pair for your chosen backend) ---
# DeepSeek (OpenAI-compatible):
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# MiMo (region-locked key — probe AMS/other regions if 401):
# MIMO_API_KEY=
# MIMO_BASE_URL=https://api.mimo.xiaomi.com/v1

# --- optional: per-role model overrides (conductor / executor leaf / plan) ---
# OMD_CG_CONDUCTOR_MODEL=deepseek:deepseek-v4-flash
# OMD_CG_LEAF_MODEL=deepseek:deepseek-v4-flash
# OMD_PLAN_MODEL=deepseek:deepseek-v4-pro

# --- optional: token budget ceiling (USD) for sub-orchestration ---
# OMD_BUDGET_USD=5

# --- optional: web stack (search + fetch). Without keys, web tools stay disabled. ---
# TAVILY_API_KEY=
# ANYSEARCH_API_KEY=
# FIRECRAWL_API_KEY=

# --- optional: DAG engine tuning (ported core) ---
# OMD_MAX_FANOUT=8                 # concurrent leaf cap (default min(16, cores-2))
# OMD_LEAF_OVERFLOW_MODEL=         # long-context overflow model for oversized leaves
# OMD_DATA_HOME=                   # checkpoint/continuity root (default .omd/)
# OMD_VERIFY=0                     # disable the cross-model verifier
# OMD_VERIFY_GATE=0                # disable the edit→verify tool gate
# OMD_ESCAPE_HATCH=1               # enable the capped imperative escape-hatch primitive

# --- logging ---
# LOG_LEVEL=info
# NODE_ENV=development
