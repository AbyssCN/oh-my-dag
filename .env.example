# --- valar runtime: pick any supported / OpenAI-compatible backend ---
# The agent has NO baked default — set both, or pass --provider/--model.
VALAR_RUNTIME_PROVIDER=deepseek
VALAR_RUNTIME_MODEL=deepseek-v4-pro

# --- optional: per-role model overrides (conductor / executor leaf / plan) ---
# VALAR_CG_CONDUCTOR_MODEL=deepseek:deepseek-v4-flash
# VALAR_CG_LEAF_MODEL=deepseek:deepseek-v4-flash
# VALAR_PLAN_MODEL=deepseek:deepseek-v4-pro

# --- optional: token budget ceiling (USD) for sub-orchestration ---
# VALAR_BUDGET_USD=5

# --- optional: web stack (search + fetch). Without keys, web tools stay disabled. ---
# TAVILY_API_KEY=
# ANYSEARCH_API_KEY=
# FIRECRAWL_API_KEY=

# --- logging ---
# LOG_LEVEL=info
# NODE_ENV=development
