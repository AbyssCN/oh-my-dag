# =============================================================================
# Easiest path: run `omd init` — an interactive wizard configures the keys,
# picks a model, probes reachability, and writes this .env for you.
# Or set the values below manually.
#
# Naming note: OMD_* is the primary prefix. Legacy XIHE_* names are still
# accepted (mapped onto the OMD_* twin when it is unset — see src/env-alias.ts).
# =============================================================================

# --- runtime: pick any supported / OpenAI-compatible backend ---
# The agent has NO baked default — set both, or pass --provider/--model.
OMD_RUNTIME_PROVIDER=deepseek
OMD_RUNTIME_MODEL=deepseek-v4-pro

# --- provider credentials (set the pair for your chosen backend) ---
# DeepSeek (OpenAI-compatible):
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# MiMo (region-locked key — probe AMS/other regions if 401):
# MIMO_API_KEY=
# MIMO_BASE_URL=https://api.mimo.xiaomi.com/v1

# --- optional: per-role model matrix (all values are provider:model coordinates) ---
# `omd init` step ⑥ offers three guided presets that fill this whole matrix
# (definitions live in src/harness/init/role-presets.ts):
#   ① 基础档 base-opencode-go       — 一把 OPENCODE_API_KEY 走 opencode go 网关,
#     网关侧多家族混编: deepseek-v4 pro 关键角色 / flash 铺量, qwen3.7-plus agent+多模态,
#     glm-5.2 合成 + verifier 跨家族 (单 key 实现)。
#   ② 中间档 cn-standard            — deepseek v4 直连: pro 关键角色 (plan/judge/reason/
#     escalation), flash 铺量 (conductor/leaf/agent/lens/reduce), mimo-2.5 多模态 + verifier。
#   ③ 顶配档 cn-ultimate            — kimi k3 掌舵 (runtime/plan/conductor/escalation),
#     deepseek pro 评判/终审/合成, qwen plus 干活 / max verifier, zhipu glm-5.2 审 review
#     Spec 轴 + premium 多模态, mimo ultraspeed 极速多模态, router 池 bandit 在 qwen/mimo 间选型。
#
# code-graph (/cg) pipeline roles:
# OMD_CG_CONDUCTOR_MODEL=deepseek:deepseek-v4-flash   # cg 分解 conductor
# OMD_CG_LEAF_MODEL=deepseek:deepseek-v4-flash        # cg inproc leaf
# OMD_CG_AGENT_MODEL=deepseek:deepseek-v4-flash       # cg agent leaf (own-loop)
# iterative pipeline roles:
# OMD_ITER_CONDUCTOR_MODEL=deepseek:deepseek-v4-flash # iter 分解 conductor
# OMD_ITER_LEAF_MODEL=deepseek:deepseek-v4-flash      # iter inproc leaf
# OMD_ITER_AGENT_MODEL=deepseek:deepseek-v4-flash     # iter agent leaf
# escalation / deliberation roles:
# OMD_CONDUCTOR_ESCALATION_MODEL=deepseek:deepseek-v4-pro  # conductor 卡壳升级档
# OMD_PLAN_MODEL=deepseek:deepseek-v4-pro             # plan 审议座舱
# research fanout roles:
# OMD_LENS_MODEL=deepseek:deepseek-v4-flash           # 镜头 (per-lens 探索)
# OMD_REASON_MODEL=deepseek:deepseek-v4-pro           # synth / 终审推理
# OMD_REDUCE_MODEL=deepseek:deepseek-v4-flash         # per-lens V→1 冠军合成
# OMD_JUDGE_MODEL=deepseek:deepseek-v4-pro            # 评判
# OMD_REVIEW_SPEC_MODEL=zhipu:glm-5.2                 # review Spec 轴 (对抗审查) 专用模型
# router bandit pools (逗号分隔坐标表, pool[0] = 静态默认):
# OMD_ROUTER_POOL_INPROC=deepseek:deepseek-v4-flash
# OMD_ROUTER_POOL_AGENT=deepseek:deepseek-v4-flash
# (multimodal 双层池 (便宜层+贵层) + verifier 跨家族 + custom API 端点落 .omd/config.json,
#  由 omd init preset / TUI /config 写, 不走 env。)

# --- optional: token budget ceiling (USD) for sub-orchestration ---
# OMD_BUDGET_USD=5

# --- optional: web stack (search + fetch). Without keys, web tools stay disabled. ---
# TAVILY_API_KEY=
# ANYSEARCH_API_KEY=
# FIRECRAWL_API_KEY=

# --- optional: DAG engine tuning (ported core) ---
# OMD_MAX_FANOUT=8                 # concurrent leaf cap (default min(16, cores-2))
# OMD_LEAF_OVERFLOW_MODEL=         # long-context overflow model for oversized leaves
# OMD_DATA_HOME=                   # checkpoint/continuity root (default .omd/)
# OMD_VERIFY=0                     # disable the cross-model verifier
# OMD_VERIFY_GATE=0                # disable the edit→verify tool gate
# OMD_ESCAPE_HATCH=1               # enable the capped imperative escape-hatch primitive

# --- logging ---
# LOG_LEVEL=info
# NODE_ENV=development
